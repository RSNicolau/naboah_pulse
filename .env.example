# =============================================================================
# Naboah Pulse — Environment Variables Template
# Copy this file and fill in the values:
#   Backend  →  apps/api/.env
#   Frontend →  apps/web/.env.local
# =============================================================================

# ─── Supabase (shared) ───────────────────────────────────────────────────────
# Project URL from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co

# service_role key (backend only — keep secret)
SUPABASE_KEY=<your-supabase-service-role-key>

# anon/public key (frontend — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase → Project → Settings → Database)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── Backend API ─────────────────────────────────────────────────────────────
# JWT settings (used by auth_utils.py)
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Port (Railway injects this automatically)
PORT=8000

# ─── Frontend → API ──────────────────────────────────────────────────────────
# URL of the deployed API (Railway public URL)
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production frontend URL (added to allowed origins in main.py)
FRONTEND_URL=https://your-app.vercel.app

# ─── AI / Claude ─────────────────────────────────────────────────────────────
# Anthropic API key — used by Content Studio to generate marketing copy
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ────────────────────────────────────────────────────────────────
# Redis (used by some workers — leave empty if not configured)
REDIS_URL=redis://localhost:6379
